# ----------------------------------------------------------------
# Variables d'environnement Claire Platform
# Copie ce fichier en .env.local et remplis les valeurs
# Ne JAMAIS commit le fichier .env.local
# ----------------------------------------------------------------

# Supabase (récupère depuis Settings → API de ton projet Supabase)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Anthropic (pour le chatbot Claire)
ANTHROPIC_API_KEY=sk-ant-...

# Webhook d'automatisation pour notifier le cabinet (optionnel) — compatible Make,
# n8n, Zapier… Voir docs/MAKE.md pour la recette Make pas à pas.
NOTIFY_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxx
# Secret partagé envoyé en en-tête X-Claire-Secret au webhook (recommandé si
# NOTIFY_WEBHOOK_URL est défini) : permet à l'automatisation de rejeter les appels non authentifiés.
NOTIFY_WEBHOOK_SECRET=
# (Rétrocompatibilité : N8N_WEBHOOK_URL / N8N_WEBHOOK_SECRET restent acceptés si déjà configurés.)

# Origines autorisées pour les endpoints publics (/api/chat, /api/contact)
# Séparer par virgule. Mettre '*' pour autoriser tout le monde (déconseillé en prod).
# Exemple : https://claireassistante.fr,https://www.claireassistante.fr
ALLOWED_ORIGINS=https://claireassistante.fr,https://www.claireassistante.fr

# Cabinet de démonstration (page d'accueil) — UUID du cabinet "Démo".
# Active la carte "ce que reçoit le cabinet" sous la démo (/api/demo-summary).
# Doit correspondre à DEMO_CABINET_ID dans js/demo-chat.js.
DEMO_CABINET_ID=

# Administrateur(s) autorisé(s) à inviter de nouveaux cabinets (/api/invite-cabinet).
# Liste d'emails séparés par des virgules. Seuls ces comptes voient l'outil "Inviter un cabinet".
# Exemple : contact@claireassistante.fr
ADMIN_EMAILS=

# URL publique du site, utilisée comme lien de retour dans l'email d'invitation
# (page /bienvenue.html). Optionnel : déduit automatiquement si absent.
# Exemple : https://app.claireassistante.fr
PUBLIC_SITE_URL=
